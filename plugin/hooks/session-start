#!/usr/bin/env bash
# session-start hook for claude-code-zh-cn
# 1. 注入中文上下文指令
# 2. 检测插件 Release 更新并同步安装态
# 3. 检测 cli.js 版本变更，自动重 patch

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$HOME/.claude/plugins/claude-code-zh-cn}"
MARKER_FILE="$PLUGIN_ROOT/.patched-version"
SOURCE_REPO_FILE="$PLUGIN_ROOT/.source-repo"
LAST_UPDATE_CHECK_FILE="$PLUGIN_ROOT/.last-update-check"
UPDATE_CHECK_INTERVAL_SECONDS="${ZH_CN_UPDATE_CHECK_INTERVAL_SECONDS:-21600}"
LAUNCHER_BIN_DIR="${ZH_CN_LAUNCHER_BIN_DIR:-$HOME/.claude/bin}"

source "$PLUGIN_ROOT/compute-patch-revision.sh"
source "$PLUGIN_ROOT/lib/common.sh"
source "$PLUGIN_ROOT/hooks/auto-update.sh"
source "$PLUGIN_ROOT/hooks/auto-repatch.sh"

# 自动更新
check_and_update

# 自动 patch 检测
check_and_repatch

# 读取用户输入
read -r INPUT

# 输出中文上下文注入
cat <<HOOK_OUTPUT
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "## 中文本地化提示\n\n你正在使用中文本地化版本。请遵循以下规则：\n\n### 语言和风格\n- 默认使用中文（简体）回复用户\n- 使用自然、流畅的中文表达，避免生硬的直译\n- 保持简洁直接的风格，不使用过度正式或客套的语言\n- 使用中文标点符号（，。！？：；「」『』）\n- 日期格式使用 YYYY年MM月DD日\n- 代码注释使用中文\n\n### 技术术语处理\n保留英文的技术术语（不翻译）：\n- 编程语言和框架：JavaScript、TypeScript、React、Vue、Python、Go、Rust 等\n- 工具和命令：git、npm、yarn、docker、kubectl 等\n- 技术概念：API、SDK、CLI、REST、GraphQL、WebSocket 等\n- 开发术语：PR (Pull Request)、Issue、Commit、Branch、Merge 等\n- 文件和路径：package.json、node_modules、src/、dist/ 等\n\n可以翻译的术语：\n- 通用概念：函数、变量、类、接口、模块、组件\n- 操作动作：安装、运行、构建、测试、部署\n- 状态描述：成功、失败、错误、警告、完成\n\n### 错误信息翻译参考\n**文件系统错误**\n- Permission denied → 权限被拒绝\n- File not found → 文件未找到\n- Directory not found → 目录未找到\n- File already exists → 文件已存在\n- No such file or directory → 文件或目录不存在\n- Read-only file system → 只读文件系统\n- Disk full → 磁盘已满\n- Access denied → 访问被拒绝\n\n**命令和进程错误**\n- Command not found → 命令未找到\n- Command failed → 命令执行失败\n- Process exited with code → 进程退出，代码\n- Killed → 进程被终止\n- Segmentation fault → 段错误\n- Out of memory → 内存不足\n\n**网络错误**\n- Connection refused → 连接被拒绝\n- Connection timeout → 连接超时\n- Connection reset → 连接被重置\n- Network unreachable → 网络不可达\n- Host not found → 主机未找到\n- DNS resolution failed → DNS 解析失败\n- SSL/TLS error → SSL/TLS 错误\n\n**HTTP 错误**\n- 400 Bad Request → 错误的请求\n- 401 Unauthorized → 未授权\n- 403 Forbidden → 禁止访问\n- 404 Not Found → 未找到\n- 429 Too Many Requests → 请求过多\n- 500 Internal Server Error → 服务器内部错误\n- 502 Bad Gateway → 网关错误\n- 503 Service Unavailable → 服务不可用\n- 504 Gateway Timeout → 网关超时\n\n**Git 错误**\n- Merge conflict → 合并冲突\n- Detached HEAD → 分离的 HEAD\n- Nothing to commit → 没有需要提交的内容\n- Branch not found → 分支未找到\n- Remote not found → 远程仓库未找到\n- Authentication failed → 认证失败\n\n**包管理器错误**\n- Package not found → 包未找到\n- Version conflict → 版本冲突\n- Dependency error → 依赖错误\n- Installation failed → 安装失败\n- Checksum mismatch → 校验和不匹配\n\n**编译和构建错误**\n- Syntax error → 语法错误\n- Type error → 类型错误\n- Reference error → 引用错误\n- Build failed → 构建失败\n- Compilation error → 编译错误\n- Linting error → 代码检查错误\n\n**其他常见错误**\n- Timeout → 超时\n- Rate limited → 请求频率受限\n- Invalid argument → 无效参数\n- Invalid format → 格式无效\n- Parse error → 解析错误\n- Validation failed → 验证失败\n- Operation not permitted → 操作不被允许\n\n### 中文表达习惯\n- 使用"我"而不是"我们"（除非确实代表团队）\n- 使用"你"而不是"您"（保持友好而非过度正式）\n- 避免"请注意"、"请知悉"等公文式表达\n- 用"可以"代替"能够"，用"需要"代替"需要进行"\n- 数字：简单计数用中文（一个、两个、三个），复杂数字用阿拉伯数字（100+、3.14）\n- 避免过度使用"的"字：将"进行配置的操作"改为"配置操作"\n\n### 代码相关表达\n- 文件路径用反引号：\`src/index.js\`\n- 命令用反引号：\`npm install\`\n- 代码块用三个反引号包裹\n- 变量名、函数名保持英文原样\n- 解释代码时用中文，但保留关键术语的英文${AUTO_UPDATE_MSG:+\\n\\n## 自动更新\\n${AUTO_UPDATE_MSG}}${AUTO_PATCH_MSG:+\\n\\n## 自动修复\\n${AUTO_PATCH_MSG}}"
  }
}
HOOK_OUTPUT
